{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.1"}
        org.clojure/tools.namespace {:mvn/version "1.5.1"}}

 :aliases
 {;; Plain clojure.test + scry development/tests.
  :test {:extra-paths ["test" "bb"]}

  ;; Kaocha adapter. The scry.kaocha namespace lives on this path so the
  ;; core never depends on kaocha being present.
  :kaocha {:extra-paths ["src-kaocha"]
           :extra-deps {lambdaisland/kaocha {:mvn/version "1.91.1392"}}}

  ;; Maintainer build tasks. Use with clojure -T:build clean, jar, kaocha-jar, or jars.
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.10"}}
          :ns-default build}

  ;; Maintainer deploy support. Use with clojure -T:build:deploy deploy or deploy-all.
  :deploy {:extra-deps {slipset/deps-deploy {:mvn/version "0.2.2"}}}

  ;; Focused release helper tests. Adds bb/ so Clojure can load the
  ;; Babashka-compatible release helper namespace.
  :release-test {:extra-paths ["bb"]}

  :nrepl {:extra-deps {nrepl/nrepl {:mvn/version "1.3.1"}
                       cider/cider-nrepl {:mvn/version "0.55.7"}}
          :main-opts ["-m" "nrepl.cmdline"
                      "--middleware" "[cider.nrepl/cider-middleware]"]}}}
